# Client-visible Firebase config (safe to be public; required for web SDK)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Backend API base URL (your FastAPI deployment URL)
NEXT_PUBLIC_API_URL=

# Optional (only if you want to force OAuth redirect base)
NEXT_PUBLIC_APP_URL=

# Server-only (Next.js route handlers use these; do NOT expose in client code)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
